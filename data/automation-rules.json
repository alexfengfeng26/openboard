[
  {
    "id": "rule-1746751234568-ghi456jkl",
    "name": "完成时移除进行中标签",
    "description": "当卡片移动到标题包含 \"已完成\" 或 \"Done\" 的列表时，自动移除 \"进行中\" 标签",
    "enabled": true,
    "trigger": {
      "type": "card_moved",
      "conditions": [
        {
          "field": "toLaneId",
          "operator": "contains",
          "value": "已完成"
        }
      ]
    },
    "actions": [
      {
        "type": "remove_tag",
        "params": {
          "tagId": "in-progress"
        }
      }
    ],
    "createdAt": "2025-05-09T10:00:00.000Z",
    "updatedAt": "2025-05-09T10:00:00.000Z",
    "boardId": ""
  },
